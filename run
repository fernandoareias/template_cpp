#!/usr/bin/env bash
set -euo pipefail

BUILD_DIR="build"
BUILD_TYPE="${CMAKE_BUILD_TYPE:-Debug}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    echo "Usage: $0 <command> [module|all]"
    echo ""
    echo "Commands:"
    echo "  build [module|all]   Build a specific module or all modules (default: all)"
    echo "  run   [module|all]   Run a specific module or all modules  (default: all)"
    echo "  test  [module|all]   Run tests for a module or all modules (default: all)"
    echo "  clean                Remove the build directory"
    echo ""
    echo "Examples:"
    echo "  $0 build module-a    # Build only module-a"
    echo "  $0 build all         # Build all modules"
    echo "  $0 run   module-a    # Run module-a"
    echo "  $0 run   all         # Run all modules"
    echo "  $0 test  module-a    # Test module-a"
    echo "  $0 test  all         # Test all modules"
    exit 1
}

configure() {
    cmake -B "${SCRIPT_DIR}/${BUILD_DIR}" \
          -DCMAKE_BUILD_TYPE="${BUILD_TYPE}" \
          -DCMAKE_EXPORT_COMPILE_COMMANDS=ON \
          -S "${SCRIPT_DIR}"
}

cmd_build() {
    local target="${1:-all}"
    configure
    if [[ "$target" == "all" ]]; then
        cmake --build "${SCRIPT_DIR}/${BUILD_DIR}"
    else
        cmake --build "${SCRIPT_DIR}/${BUILD_DIR}" --target "$target"
    fi
}

cmd_run() {
    local target="${1:-all}"
    local bin_dir="${SCRIPT_DIR}/${BUILD_DIR}/bin"

    if [[ "$target" == "all" ]]; then
        if [[ ! -d "$bin_dir" ]]; then
            echo "Error: no binaries found — run '$0 build all' first."
            exit 1
        fi
        while IFS= read -r exe; do
            echo "=== $(basename "$exe") ==="
            "$exe"
            echo ""
        done < <(find "$bin_dir" -maxdepth 1 -type f -executable | grep -v '\-tests$' | sort)
    else
        local exe="${bin_dir}/${target}"
        if [[ ! -f "$exe" ]]; then
            echo "Error: '${target}' not found — run '$0 build ${target}' first."
            exit 1
        fi
        "$exe"
    fi
}

cmd_test() {
    local target="${1:-all}"
    configure
    if [[ "$target" == "all" ]]; then
        (cd "${SCRIPT_DIR}/${BUILD_DIR}" && ctest --output-on-failure)
    else
        (cd "${SCRIPT_DIR}/${BUILD_DIR}" && ctest -R "^${target}-tests" --output-on-failure)
    fi
}

cmd_clean() {
    rm -rf "${SCRIPT_DIR}/${BUILD_DIR}"
    echo "Removed ${BUILD_DIR}/"
}

[[ $# -lt 1 ]] && usage

COMMAND="$1"
TARGET="${2:-all}"

case "$COMMAND" in
    build) cmd_build "$TARGET" ;;
    run)   cmd_run   "$TARGET" ;;
    test)  cmd_test  "$TARGET" ;;
    clean) cmd_clean ;;
    -h|--help) usage ;;
    *) echo "Unknown command: $COMMAND"; usage ;;
esac
